{
  "name": "mut-state",
  "version": "0.0.1",
  "source": "./src/index.ts",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "type": "module",
  "private": false,
  "scripts": {
    "clean": "rm -rf dist",
    "build:esm": "tsc -p tsconfig.build.esm.json",
    "build:cjs": "tsc -p tsconfig.build.cjs.json",
    "build:types": "tsc -p tsconfig.build.types.json",
    "build:cjs:package": "mkdir -p dist/cjs && printf '{\"type\":\"commonjs\"}\\n' > dist/cjs/package.json",
    "build": "bun run clean && bun run build:esm && bun run build:cjs && bun run build:types && bun run build:cjs:package",
    "typecheck": "tsc --noEmit",
    "test": "bun test --preload ./happydom.ts",
    "bench": "bun test ./benchmarks/__tests__/mutation-benchmark.bench.ts ./benchmarks/__tests__/react-graph-benchmark.bench.ts --preload ./happydom.ts",
    "lint": "eslint . --ignore-pattern dist",
    "prettier": "prettier --check .",
    "code-check": "bun typecheck && bun run test && bun run lint && bun run prettier"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@happy-dom/global-registrator": "^20.8.3",
    "@reduxjs/toolkit": "^2.11.2",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@stylistic/eslint-plugin-jsx": "^4.4.1",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/use-sync-external-store": "^1.5.0",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-perf": "^3.3.3",
    "eslint-plugin-sonarjs": "^4.0.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "immer": "^11.1.4",
    "jotai": "^2.18.0",
    "mutative": "^1.3.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "tinybench": "^6.0.0",
    "typescript-eslint": "^8.56.1",
    "zustand": "^5.0.11"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "typescript": "^5"
  },
  "dependencies": {
    "use-sync-external-store": "^1.6.0"
  }
}
